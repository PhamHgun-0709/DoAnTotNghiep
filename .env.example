# ============================================================================
# Ad Campaign Optimization System - Environment Configuration
# ============================================================================

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_WORKERS=4

# Database Connection
# For Docker Compose: use service name 'db'
# For local development: use 'localhost'
DATABASE_URL=postgresql+psycopg://<user>:<password>@<host>:<port>/<database>
DB_HOST=db
DB_PORT=5432
DB_NAME=ads_db
DB_USER=ads_user
DB_PASSWORD=<set-a-password>
DB_ECHO=false

# Frontend Configuration
FRONTEND_URL=http://127.0.0.1:8080
FRONTEND_PORT=8080

# CORS Settings (comma-separated origins)
CORS_ORIGINS=http://127.0.0.1:8080,http://localhost:8080,http://127.0.0.1:3000

# Feature Flags
INTERNAL_MODE=true              # Enable ops/admin sections in dashboard
ENABLE_ML_ENDPOINTS=true        # Enable ML training/prediction endpoints
ENABLE_EXPERIMENTS=true         # Enable experiment tracking

# ML Configuration
ML_MODEL_PATH=data/curated/models/
ML_CLASSIFIER_MODEL=campaign_classifier.joblib
ML_PREDICTOR_MODEL=conversion_predictor.joblib
ML_DEFAULT_REVENUE_PER_CONVERSION=10.0

# Data Configuration
DATA_CSV_PATH=data/processed/ad_quality/
DATA_BUDGET_RECOMMENDATIONS_PATH=data/curated/budget_recommendations/
DATA_UPLOAD_LIMIT_MB=500

# Session Configuration
SESSION_EXPIRY_MINUTES=480      # 8 hours
SESSION_SECURE_COOKIES=false    # Set to true in production HTTPS
SESSION_HTTPONLY=true
SESSION_SAMESITE=Lax

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Production Deployment (use when deploying to production)
# ENVIRONMENT=production
# AUTH_SECRET=<set-a-long-random-secret>
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# HTTPS_REDIRECT=true

# Admin bootstrap
ADMIN_USERNAME=admin
ADMIN_PASSWORD=<set-admin-password>
ADMIN_EMAIL=admin@example.com

